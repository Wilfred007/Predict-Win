    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^16.3.0",
    "hardhat": "^2.20.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.0",
    "vite": "^8.0.13"
  }
}
