# Copy this file to .env and set values before deploying
ALFAJORES_URL=https://alfajores-forno.celo-testnet.org
PRIVATE_KEY=your_private_key_here
VITE_ONBOARDING_CONTRACT_ADDRESS=0xYourDeployedContractAddress
# Groq API key — get one at https://console.groq.com
# Warning: this key is exposed in the browser bundle; use a backend proxy in production
VITE_GROQ_API_KEY=your_groq_api_key_here
# Deploy PredictionMarket.sol and paste the address here
VITE_PREDICTION_MARKET_ADDRESS=your_deployed_contract_address
